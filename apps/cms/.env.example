# Payload
PAYLOAD_SECRET=

# Postgres connection string (Neon, Supabase, local Postgres, ...)
DATABASE_URL=

# Cloudflare R2 (S3-compatible)
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# Cron auth — Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=

# Web Push (VAPID) — one platform-wide keypair. Generate with:
#   npx web-push generate-vapid-keys
# Public key also goes to each frontend as NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@moslavac.hr

# Google Gemini (AI auto-draft izvještaja)
GEMINI_API_KEY=
# Optional override (default gemini-2.5-flash)
GEMINI_MODEL=

# Optional: comma-separated allowed CORS origins (frontend URLs). Defaults to *.
CORS_ORIGINS=
