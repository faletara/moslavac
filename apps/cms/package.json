{
	"name": "@moslavac/cms",
	"version": "0.1.0",
	"description": "Payload CMS backend for clubs platform (multi-tenant)",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
		"dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3002",
		"devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev -p 3002",
		"generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
		"generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
		"lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
		"payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
		"start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3002"
	},
	"dependencies": {
		"@payloadcms/db-postgres": "latest",
		"@payloadcms/next": "latest",
		"@payloadcms/plugin-multi-tenant": "latest",
		"@payloadcms/richtext-lexical": "latest",
		"@payloadcms/storage-s3": "latest",
		"@payloadcms/ui": "latest",
		"cross-env": "^7.0.3",
		"dotenv": "^16.4.7",
		"graphql": "^16.8.1",
		"next": "^16.2.3",
		"payload": "latest",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"sharp": "^0.34.2",
		"undici": "^6.25.0"
	},
	"devDependencies": {
		"@types/node": "^22.19.9",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^9.16.0",
		"eslint-config-next": "^16.2.3",
		"pg": "^8.20.0",
		"prettier": "^3.4.2",
		"typescript": "^5.7.3"
	},
	"engines": {
		"node": "^18.20.2 || >=20.9.0",
		"pnpm": "^9 || ^10"
	}
}
