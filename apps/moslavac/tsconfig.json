{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/types/*": ["../../packages/types/src/*"],
      "@/lib/payload/*": ["../../packages/payload/src/*"],
      "@/lib/hns/*": ["../../packages/hns/src/*"],
      "@/lib/pwa/*": ["../../packages/pwa/src/*"],
      "@/components/ui/*": ["../../packages/ui/src/*"],
      "@/lib/utils": ["../../packages/ui/src/utils"],
      "@/components/analytics/*": ["../../packages/ui/src/analytics/*"],
      "@/lib/helpers/*": ["../../packages/lib/src/helpers/*"],
      "@/lib/app-shell/*": ["../../packages/app-shell/src/*"],
      "@/components/animations": ["../../packages/ui/src/animations/index"],
      "@/components/animations/*": ["../../packages/ui/src/animations/*"],
      "@/components/providers/*": ["../../packages/app-shell/src/providers/*"],
      "@/components/feedback/*": ["../../packages/app-shell/src/feedback/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
